import java.util.*;

class Main{
	public static void main(String args[])
	{
		Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        int arr[]=new int[n];
        for(int i=0;i<n;i++) arr[i]=sc.nextInt();
        Arrays.sort(arr);
        ArrayList<Integer> li=new ArrayList<>();
        for(int i=0;i<(n+1)/2;i++) li.add(arr[i]);
        for(int i=n-1;i>=(n+1)/2;i--) li.add(arr[i]);
        for(int ele:li) System.out.print(ele+" ");
	}
}
