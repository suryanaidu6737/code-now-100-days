class Solution {
    public static int[] solvemoveMultiplesOfTen(int n, int[] arr) {
        int ans[]=new int[n];
        int j=0;
        for(int i=0;i<n;i++){
            if(arr[i]%10!=0){
                ans[j]=arr[i];
                j++;
            } 
        }
        for(int i=0;i<n;i++){
            if(arr[i]%10==0){
                ans[j]=arr[i];
                j++;
            } 
        }
        return ans;
    }
}
