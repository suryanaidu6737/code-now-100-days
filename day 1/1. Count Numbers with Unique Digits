class Solution {
    public static int countUniqueDigitNumbers(int n1, int n2) {
        int count=0;
        for(int i=n1;i<=n2;i++){
            if(unique(i)) count++;
        }
        return count;
    }
    public static boolean unique(int n){
        boolean arr[]=new boolean[10];
        while(n>0){
            int rem=n%10;
            if(arr[rem]==true) return false;
            arr[rem]=true;
            n/=10;
        }
        return true;
    }
}
